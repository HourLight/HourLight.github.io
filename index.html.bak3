}

@keyframes hl-lucky-wobble {
  0%, 100% { transform: rotate(-5deg) scale(1); }
  50%       { transform: rotate(5deg) scale(1.08); }
}

.hl-lucky-fab-pulse {
  position: absolute;
  inset: -4px;
