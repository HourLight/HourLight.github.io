<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>馥靈之鑰 Hour Light｜生命數字×芳香牌卡×情緒覺察｜線上免費測算</title>
<meta name="description" content="馥靈之鑰｜輸入農曆生日，免費解碼你的生命數字與性格藍圖。130張芳香牌卡線上抽牌，一對一情緒覺察諮詢。不是算命，是幫你看清自己的方向。創辦人王逸君｜健康產業管理碩士×30年美業實戰×NAHA國際芳療師。">
<link rel="icon" href="favicon.ico">
<!-- PWA & Apple Touch Icon -->
<link rel="apple-touch-icon" sizes="180x180" href="apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="icon-32.png">
<link rel="icon" type="image/png" sizes="16x16" href="icon-16.png">
<link rel="manifest" href="manifest.json">
<meta name="theme-color" content="#e9c27d">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="馥靈之鑰">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=LXGW+WenKai+TC:wght@300;400;700&family=Noto+Serif+TC:wght@300;400;500&family=Noto+Sans+TC:wght@300;400;500&display=swap" rel="stylesheet">

<link rel="stylesheet" href="assets/css/hourlight-global.css">
<style>
/* ==============================
   馥靈之鑰 Hour Light
   黑金宇宙主題
   ============================== */

:root {
  --font-main:"Noto Sans TC","PingFang TC","Microsoft JhengHei",system-ui,sans-serif;
  --font-serif:"LXGW WenKai TC","Noto Serif TC",serif;

  /* 黑金宇宙色系 */
  --hl-bg: #05030a;
  --hl-bg-soft: #0d0917;
  --hl-card: rgba(12,8,24,0.92);
  --hl-border: rgba(233,194,125,0.25);

  --hl-gold: #e9c27d;
  --hl-gold-deep: #cda86e;
  --hl-gold-soft: #a88257;

  --hl-ink: #f7efe1;
  --hl-ink-soft: #c4b7a6;
  --hl-ink-muted: #aca090;

  --hl-plum: #9c6edb;
  --hl-plum-deep: #5c3a80;

  --hl-ease: cubic-bezier(0.4, 0, 0.2, 1);
}

/* Reset */
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased;}

body {
  min-height: 100vh;
  font-family: var(--font-main);
  color: var(--hl-ink);
  line-height: 1.9;
  font-weight: 300;
  letter-spacing: 0.3px;
  background-color: var(--hl-bg);
}

.container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 40px 24px 60px;
}

.card {
  border-radius: 20px;
  margin-bottom: 24px;
  overflow: clip;  /* clip 不影響 transform，解決 hover 被裁切問題 */
  backdrop-filter: blur(24px) saturate(160%);
  -webkit-backdrop-filter: blur(24px) saturate(160%);
  background:
    radial-gradient(circle at top left, rgba(233,194,125,0.12), transparent 55%),
    radial-gradient(circle at bottom right, rgba(92,58,128,0.06), transparent 50%),
    rgba(10,6,24,0.82);
  border: 1px solid rgba(233,194,125,0.25);
  box-shadow:
    0 20px 50px rgba(0,0,0,0.7),
    0 0 1px rgba(233,194,125,0.3),
    inset 0 1px 0 rgba(233,194,125,0.08);
}

/* ====== Hero 區 ====== */
.hero-card {
  border-color: rgba(233,194,125,0.35);
  background:
    radial-gradient(ellipse at 50% 30%, rgba(233,194,125,0.10), transparent 60%),
    radial-gradient(circle at 50% 80%, rgba(92,58,128,0.06), transparent 50%),
    rgba(8,5,18,0.92);
}

.hero {
  text-align: center;
  padding: 80px 40px 60px;
  position: relative;
  overflow: hidden;
}

.hero-label {
  font-size: 0.68rem;
  color: var(--hl-gold);
  letter-spacing: 4px;
  margin-bottom: 16px;
  text-transform: uppercase;
  font-weight: 300;
  opacity: 0.6;
}

.hero-brand-name {
  font-family: var(--font-serif);
  font-size: clamp(1.4rem, 3.5vw, 1.9rem);
  color: var(--hl-gold);
  letter-spacing: 3px;
  font-weight: 300;
  margin-bottom: 28px;
  opacity: 0.85;
}

.hero-title {
  font-family: var(--font-serif);
  font-size: clamp(1.6rem, 4.5vw, 2.2rem);
  font-weight: 300;
  letter-spacing: 1.5px;
  margin-bottom: 28px;
  line-height: 1.5;
  background: linear-gradient(135deg, #fff9ea 0%, #fbe6c2 20%, #e9c27d 50%, #cda86e 75%, #fff9ea 100%);
  background-size: 200% 200%;
  animation: heroTitleShimmer 6s ease infinite;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.hero-philosophy {
  font-family: var(--font-main);
  font-size: clamp(0.88rem, 2.2vw, 1rem);
  color: var(--hl-ink-soft);
  max-width: 520px;
  margin: 0 auto 28px;
  line-height: 2.2;
  letter-spacing: 0.5px;
  font-weight: 300;
  opacity: 0.85;
}

.hero-divider {
  width: 40px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--hl-gold), transparent);
  margin: 0 auto 28px;
}

.hero-desc {
  font-size: 0.9rem;
  max-width: 560px;
  margin: 0 auto 36px;
  color: var(--hl-ink-soft);
  line-height: 2.1;
  font-weight: 300;
  letter-spacing: 0.3px;
}

/* 雙按鈕區 */
.hero-cta-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  margin-bottom: 20px;
}

.hero-cta-main {
  display: inline-block;
  padding: 16px 48px;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--hl-gold), var(--hl-gold-deep));
  color: #20120a;
  text-decoration: none;
  letter-spacing: 1.5px;
  font-size: 0.9rem;
  font-weight: 500;
  transition: all .3s ease;
  box-shadow:
    0 10px 26px rgba(0,0,0,0.9),
    0 0 20px rgba(233,194,125,0.65);
  border: none;
}

.hero-cta-main:hover {
  transform: translateY(-2px);
  box-shadow:
    0 14px 34px rgba(0,0,0,0.8),
    0 0 26px rgba(233,194,125,0.6);
}

/* 金色呼吸光 CTA */
.hero-cta-shimmer {
  background: linear-gradient(135deg, #B8860B, #D4AF37, #F5E6A3, #D4AF37, #B8860B);
  background-size: 200% 200%;
  animation: goldShimmer 4s ease infinite;
  color: #2D1B0E;
  text-shadow: 0 1px 2px rgba(255,255,255,0.2);
  box-shadow:
    0 10px 26px rgba(0,0,0,0.5),
    0 0 24px rgba(212,175,55,0.4),
    0 0 50px rgba(212,175,55,0.15);
}

.hero-cta-shimmer:hover {
  box-shadow:
    0 14px 34px rgba(0,0,0,0.6),
    0 0 30px rgba(212,175,55,0.6),
    0 0 60px rgba(212,175,55,0.25);
}

.hero-cta-secondary {
  font-size: 0.88rem;
  color: var(--hl-gold);
  text-decoration: none;
  letter-spacing: 1px;
  transition: all .3s ease;
  border-bottom: 1px solid rgba(233,194,125,0.3);
  padding-bottom: 2px;
}

.hero-cta-secondary:hover {
  color: #fbe6c2;
  border-color: rgba(233,194,125,0.6);
}

.hero-secondary-links {
  display: flex;
  justify-content: center;
  gap: 24px;
  flex-wrap: wrap;
  margin-top: 8px;
}

.hero-secondary-links a {
  font-size: 0.85rem;
  color: var(--hl-ink-muted);
  text-decoration: none;
  transition: color .3s ease;
}

.hero-secondary-links a:hover {
  color: var(--hl-gold);
}

.hero-note {
  margin-top: 24px;
  font-size: 0.82rem;
  color: var(--hl-ink-muted);
}

/* ====== Section 通用 ====== */
.section {
  padding: 40px;
}

.section-header {
  text-align: center;
  margin-bottom: 32px;
}

.section-label {
  font-size: 0.7rem;
  color: var(--hl-gold);
  letter-spacing: 4px;
  margin-bottom: 12px;
  text-transform: uppercase;
  font-weight: 300;
  opacity: 0.7;
}

.section-title {
  font-family: var(--font-serif);
  font-size: clamp(1.2rem, 3.2vw, 1.5rem);
  font-weight: 300;
  background: linear-gradient(135deg, #fbe6c2, #e9c27d, #cda86e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 14px;
  letter-spacing: 1.5px;
}

.section-desc {
  font-size: 0.9rem;
  color: var(--hl-ink-soft);
  max-width: 580px;
  margin: 0 auto;
  line-height: 2;
  font-weight: 300;
}

/* ====== Grid ====== */
.grid-2, .grid-3 {
  display: grid;
  gap: 24px;
  margin-top: 24px;
}

.grid-2 {
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
}

.grid-3 {
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
}

/* ====== 主打工具卡（大卡） ====== */
.featured-tool {
  background:
    radial-gradient(circle at top left, rgba(233,194,125,0.15), transparent 60%),
    radial-gradient(circle at bottom right, rgba(92,58,128,0.08), transparent 50%),
    rgba(9,6,20,0.88);
  border-radius: 20px;
  border: 2px solid rgba(233,194,125,0.5);
  padding: 36px 28px;
  text-align: center;
  transition: all .3s ease;
  box-shadow: 
    0 14px 34px rgba(0,0,0,0.7),
    0 0 20px rgba(233,194,125,0.15);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.featured-tool::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #fbe6c2, var(--hl-gold), var(--hl-gold-deep));
}

.featured-tool:hover {
  transform: translateY(-6px);
  box-shadow: 
    0 20px 50px rgba(0,0,0,0.95), 
    0 0 40px rgba(233,194,125,0.35);
}

.featured-tool .icon {
  font-size: 3rem;
  margin-bottom: 16px;
}

.featured-tool .title {
  font-family: var(--font-serif);
  font-size: 1.4rem;
  color: var(--hl-ink);
  margin-bottom: 8px;
  font-weight: 500;
}

.featured-tool .sub {
  font-size: 0.85rem;
  color: var(--hl-gold);
  margin-bottom: 14px;
}

.featured-tool .text {
  font-size: 0.95rem;
  color: var(--hl-ink-soft);
  line-height: 1.9;
  margin-bottom: 20px;
}

/* ====== 小卡片 ====== */
.item-card {
  background:
    radial-gradient(circle at top left, rgba(233,194,125,0.1), transparent 60%),
    rgba(9,6,20,0.85);
  border-radius: 16px;
  border: 1px solid rgba(233,194,125,0.25);
  padding: 28px 24px;
  transition: all .3s ease;
  box-shadow: 0 10px 30px rgba(0,0,0,0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  display: flex;
  flex-direction: column;
  align-self: stretch;
  overflow: visible;
}

.item-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(0,0,0,0.7), 0 0 25px rgba(233,194,125,0.15);
  border-color: rgba(233,194,125,0.5);
}

.item-card .icon {
  font-size: 2rem;
  margin-bottom: 14px;
}

.item-card .title {
  font-family: var(--font-serif);
  font-size: 1.15rem;
  color: var(--hl-ink);
  margin-bottom: 8px;
  font-weight: 500;
  word-break: break-word;
  overflow-wrap: break-word;
  line-height: 1.5;
}

.item-card .sub {
  font-size: 0.85rem;
  color: var(--hl-gold);
  margin-bottom: 12px;
}

.item-card .text {
  font-size: 0.9rem;
  color: var(--hl-ink-soft);
  line-height: 1.9;
  word-break: break-word;
  overflow-wrap: break-word;
}

/* ====== 課程卡片 ====== */
.course-card {
  background:
    radial-gradient(circle at top left, rgba(233,194,125,0.1), transparent 60%),
    rgba(9,6,20,0.85);
  border-radius: 16px;
  border: 1px solid rgba(233,194,125,0.3);
  padding: 32px 28px;
  transition: all .3s ease;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0,0,0,0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.course-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, #fbe6c2, var(--hl-gold), var(--hl-gold-deep));
}

.course-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 18px 40px rgba(0,0,0,0.95), 0 0 20px rgba(233,194,125,0.25);
  border-color: var(--hl-gold);
}

.course-card .badge {
  display: inline-block;
  font-size: 0.72rem;
  padding: 5px 14px;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--hl-gold), var(--hl-gold-deep));
  color: #130c05;
  font-weight: 500;
  margin-bottom: 14px;
  letter-spacing: 1px;
}

.course-card .title {
  font-family: var(--font-serif);
  font-size: 1.25rem;
  color: var(--hl-ink);
  margin-bottom: 8px;
  font-weight: 500;
}

.course-card .instructor {
  font-size: 0.85rem;
  color: var(--hl-gold);
  margin-bottom: 14px;
}

.course-card .desc {
  font-size: 0.9rem;
  color: var(--hl-ink-soft);
  line-height: 1.9;
  margin-bottom: 16px;
}

.course-card .highlights {
  font-size: 0.85rem;
  color: var(--hl-ink-muted);
  line-height: 1.9;
  margin-bottom: 18px;
}

/* ====== 更多工具 ====== */
.tools-row {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 24px;
}

.tool-chip {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 18px;
  border-radius: 999px;
  background: rgba(9,6,20,0.6);
  border: 1px solid rgba(233,194,125,0.2);
  color: var(--hl-ink-soft);
  text-decoration: none;
  font-size: 0.88rem;
  transition: all .3s ease;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.tool-chip:hover {
  background: rgba(233,194,125,0.15);
  border-color: var(--hl-gold);
  color: var(--hl-gold);
  box-shadow: 0 4px 15px rgba(233,194,125,0.2);
}

.tool-chip .icon {
  font-size: 1.1rem;
}

/* ====== 快速分流導航 ====== */
.quick-nav {
  text-align: center;
  padding: 20px 0;
}

.quick-nav-title {
  font-size: 1rem;
  color: var(--hl-ink-muted);
  margin-bottom: 16px;
}

.quick-nav-grid {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
}

.quick-nav-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px 20px;
  background: rgba(9,6,20,0.6);
  border: 1px solid rgba(233,194,125,0.2);
  border-radius: 999px;
  text-decoration: none;
  transition: all .3s ease;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.quick-nav-item:hover {
  background: rgba(233,194,125,0.15);
  border-color: var(--hl-gold);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(233,194,125,0.2);
}

.quick-nav-icon {
  font-size: 1.2rem;
}

.quick-nav-text {
  font-size: 0.9rem;
  font-weight: 400;
  color: var(--hl-ink-soft);
}

.quick-nav-item:hover .quick-nav-text {
  color: var(--hl-gold);
}

@media (max-width: 600px) {
  .quick-nav-grid {
    display: grid;
    grid-template-columns: 1fr !important;
    gap: 12px;
  }
  .quick-nav-item {
    justify-content: center;
    padding: 10px 16px;
  }
}

/* ====== 按鈕 ====== */
.btn {
  display: inline-block;
  padding: 12px 28px;
  border-radius: 999px;
  font-size: 0.88rem;
  letter-spacing: 1px;
  text-decoration: none;
  transition: all .25s var(--hl-ease);
  margin-top: 12px;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(135deg, var(--hl-gold), var(--hl-gold-deep));
  color: #20120a;
  box-shadow:
    0 8px 24px rgba(0,0,0,0.6),
    0 0 16px rgba(233,194,125,0.4);
  border: none;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow:
    0 12px 30px rgba(0,0,0,0.7),
    0 0 22px rgba(233,194,125,0.6);
}

.btn-secondary {
  background: transparent;
  color: var(--hl-gold);
  box-shadow: none;
  border: 1.5px solid rgba(233,194,125,0.5);
}

.btn-secondary:hover {
  background: rgba(233,194,125,0.1);
  border-color: var(--hl-gold);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.5), 0 0 12px rgba(233,194,125,0.2);
}

.btn-ghost {
  background: transparent;
  color: var(--hl-ink-muted);
  border: 2px solid var(--hl-gold-soft);
}

.btn-ghost:hover {
  background: rgba(233,194,125,0.12);
  color: var(--hl-gold);
  box-shadow: 0 10px 26px rgba(0,0,0,0.9);
}

.btn-large {
  padding: 16px 36px;
  font-size: 1rem;
}

/* ====== 創辦人區塊 ====== */
.founder-section {
  display: flex;
  gap: 36px;
  align-items: center;
  margin-top: 28px;
}

.founder-photo {
  flex-shrink: 0;
  width: 140px;
  height: 180px;
  border-radius: 70px;
  overflow: hidden;
  border: 3px solid var(--hl-gold);
  box-shadow: 0 4px 20px rgba(233,194,125,0.4);
}

.founder-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top;
}

.founder-info {
  flex: 1;
}

.founder-name {
  font-family: var(--font-serif);
  font-size: 1.3rem;
  color: var(--hl-ink);
  margin-bottom: 6px;
  font-weight: 500;
}

.founder-title {
  font-size: 0.85rem;
  color: var(--hl-gold);
  margin-bottom: 14px;
}

.founder-bio {
  font-size: 0.92rem;
  color: var(--hl-ink-soft);
  line-height: 2;
}

/* ====== 書籍推薦區塊 ====== */
.books-promo {
  margin-top: 32px;
  padding-top: 28px;
  border-top: 1px solid rgba(233,194,125,0.2);
}

.books-promo-title {
  font-family: var(--font-serif);
  font-size: 1.1rem;
  color: var(--hl-gold);
  margin-bottom: 20px;
  text-align: center;
  letter-spacing: 2px;
}

.books-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 16px;
}

.book-mini-card {
  display: flex;
  align-items: center;
  gap: 14px;
  background: rgba(9,6,20,0.65);
  border: 1px solid rgba(233,194,125,0.2);
  border-radius: 12px;
  padding: 14px 16px;
  text-decoration: none;
  transition: all .3s ease;
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.book-mini-card:hover {
  border-color: var(--hl-gold);
  background: rgba(233,194,125,0.1);
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.5);
}

.book-mini-icon {
  font-size: 2rem;
  flex-shrink: 0;
}

.book-mini-cover {
  width: 45px;
  height: 65px;
  object-fit: cover;
  border-radius: 4px;
  flex-shrink: 0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.3);
}

.book-mini-info {
  flex: 1;
  min-width: 0;
}

.book-mini-tag {
  display: inline-block;
  font-size: 0.65rem;
  padding: 2px 8px;
  border-radius: 10px;
  background: rgba(233,194,125,0.2);
  color: var(--hl-gold);
  margin-bottom: 4px;
}

.book-mini-name {
  font-size: 0.9rem;
  color: var(--hl-ink);
  margin-bottom: 2px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.book-mini-desc {
  font-size: 0.75rem;
  color: var(--hl-ink-muted);
}

.book-mini-arrow {
  color: var(--hl-gold-soft);
  font-size: 1.2rem;
  transition: transform .3s ease;
}

.book-mini-card:hover .book-mini-arrow {
  transform: translateX(4px);
  color: var(--hl-gold);
}

/* ====== Footer ====== */
.footer {
  text-align: center;
  padding: 40px;
  font-size: 0.82rem;
  line-height: 2;
  color: var(--hl-ink-muted);
}

.footer strong {
  color: var(--hl-ink-soft);
}

.footer a {
  color: var(--hl-gold-soft);
  text-decoration: none;
}

.footer a:hover {
  text-decoration: underline;
  color: var(--hl-gold);
}

/* ====== 動畫 ====== */
.fade-in-up {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.fade-in-up.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* JS 未載入的安全備案 */
noscript ~ .container .fade-in-up,
.fade-in-up.is-visible { opacity: 1; transform: translateY(0); }

/* ====== RWD ====== */
@media(max-width:768px) {
  .container { padding: 24px 16px 50px; }
  .hero { padding: 40px 24px 36px; }
  .hero::before { width: 280px; height: 280px; }
  .section { padding: 32px 20px; }
  .btn { width: 100%; max-width: 280px; text-align: center; }
  .hero-cta-row { flex-direction: column; align-items: center; }
  .founder-section { flex-direction: column; text-align: center; }
  .founder-photo { margin: 0 auto; }
  .books-grid { grid-template-columns: 1fr; }
}


/* ========== 簡潔 Footer 樣式 ========== */
.hl-footer {
  background: linear-gradient(180deg, rgba(5,3,10,0.85) 0%, rgba(5,3,10,0.95) 100%);
  border-top: 1px solid rgba(233,194,125,0.15);
  padding: 40px 24px 30px;
  margin-top: 40px;
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.hl-footer-inner {
  max-width: 900px;
  margin: 0 auto;
}

/* 品牌區 */
.hl-footer-brand {
  text-align: center;
  margin-bottom: 20px;
}

.hl-footer-logo {
  font-family: var(--font-serif);
  font-size: 1.3rem;
  color: var(--hl-gold);
  letter-spacing: 2px;
  margin-bottom: 6px;
}

.hl-footer-tagline {
  font-size: 0.82rem;
  color: var(--hl-ink-muted);
}

/* 快速連結 */
.hl-footer-links {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8px 20px;
  margin-bottom: 28px;
  padding-bottom: 24px;
  border-bottom: 1px solid rgba(233,194,125,0.15);
}

.hl-footer-links a {
  font-size: 0.85rem;
  color: var(--hl-ink-soft);
  text-decoration: none;
  transition: color 0.3s ease;
}

.hl-footer-links a:hover {
  color: var(--hl-gold);
}

/* 可收合聲明區 */
.hl-footer-legal-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  cursor: pointer;
  padding: 12px 20px;
  margin: 0 auto 16px;
  background: rgba(233,194,125,0.08);
  border: 1px solid rgba(233,194,125,0.2);
  border-radius: 8px;
  font-size: 0.8rem;
  color: var(--hl-ink-muted);
  transition: all 0.3s ease;
  max-width: 280px;
}

.hl-footer-legal-toggle:hover {
  background: rgba(233,194,125,0.12);
  color: var(--hl-ink-soft);
}

.hl-footer-legal-toggle .arrow {
  transition: transform 0.3s ease;
  font-size: 0.7rem;
}

.hl-footer-legal-toggle.active .arrow {
  transform: rotate(180deg);
}

/* 收合內容區 */
.hl-footer-legal-content {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease, padding 0.3s ease;
  background: rgba(10,6,20,0.6);
  border-radius: 12px;
  margin-bottom: 20px;
}

.hl-footer-legal-content.active {
  max-height: 800px;
  padding: 24px;
  border: 1px solid rgba(233,194,125,0.15);
}

/* 聲明項目 */
.hl-legal-section {
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(233,194,125,0.1);
}

.hl-legal-section:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.hl-legal-title {
  font-size: 0.85rem;
  color: var(--hl-gold);
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.hl-legal-text {
  font-size: 0.78rem;
  color: var(--hl-ink-muted);
  line-height: 1.8;
}

.hl-legal-text strong {
  color: var(--hl-ink-soft);
}

/* 版權聲明 */
.hl-footer-copyright {
  text-align: center;
  font-size: 0.75rem;
  color: var(--hl-ink-muted);
  line-height: 1.8;
}

.hl-footer-copyright a {
  color: var(--hl-ink-muted);
  text-decoration: none;
}

.hl-footer-copyright a:hover {
  color: var(--hl-gold);
}

@media (max-width: 600px) {
  .hl-footer { padding: 30px 16px 24px; }
  .hl-footer-links { gap: 6px 16px; }
  .hl-footer-legal-content.active { padding: 18px; }
}
/* 金色發光動畫 */
@keyframes goldShimmer {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

@keyframes heroTitleShimmer {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ── 馥靈之鑰 LOGO 圖標 ── */
.hl-logo-icon {
  height: 1.15em;
  width: 1.15em;
  border-radius: 50%;
  object-fit: cover;
  vertical-align: middle;
  margin-right: 4px;
  display: inline-block;
  position: relative;
  top: -0.08em;
}
.hl-logo-hero {
  display: block;
  width: 88px;
  height: 88px;
  border-radius: 50%;
  object-fit: cover;
  margin: 0 auto 14px auto;
  filter: drop-shadow(0 0 18px rgba(233,194,125,0.55));
}

/* ====================================================
   新增模組樣式
   1. 社會證明橫條 .hl-proof-bar
   2. 見證區 .hl-testimonial-section
   3. 訂閱區 .hl-subscribe-card
   4. 手機底部固定 CTA .hl-mobile-sticky
   ==================================================== */

/* ── 1. 社會證明橫條 ── */
.hl-proof-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  flex-wrap: wrap;
  background: linear-gradient(135deg,
    rgba(233,194,125,0.06) 0%,
    rgba(92,58,128,0.04) 50%,
    rgba(233,194,125,0.06) 100%);
  border: 1px solid rgba(233,194,125,0.18);
  border-radius: 16px;
  padding: 20px 12px;
  margin-bottom: 24px;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.hl-proof-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12px 28px;
  flex: 1;
  min-width: 120px;
}

.hl-proof-num {
  font-family: var(--font-serif);
  font-size: clamp(1.5rem, 3.5vw, 2rem);
  font-weight: 300;
  letter-spacing: 1px;
  background: linear-gradient(135deg, #fff9ea, #e9c27d 50%, #cda86e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.2;
  margin-bottom: 4px;
}

.hl-proof-label {
  font-size: 0.76rem;
  color: var(--hl-ink-muted);
  letter-spacing: 1.5px;
  text-align: center;
  font-weight: 300;
}

.hl-proof-divider {
  width: 1px;
  height: 36px;
  background: rgba(233,194,125,0.2);
  flex-shrink: 0;
}

@media (max-width: 600px) {
  .hl-proof-bar { gap: 0; padding: 16px 8px; }
  .hl-proof-item { padding: 10px 14px; min-width: 80px; }
  .hl-proof-num { font-size: 1.3rem; }
  .hl-proof-label { font-size: 0.68rem; letter-spacing: 0.5px; }
  .hl-proof-divider { height: 28px; }
}

/* ── 2. 見證區 ── */
.hl-testimonial-section {
  background:
    radial-gradient(ellipse at top right, rgba(156,110,219,0.07), transparent 55%),
    rgba(8,5,18,0.88);
}

.hl-testi-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  max-width: 900px;
  margin: 0 auto;
}

@media (max-width: 768px) {
  .hl-testi-grid { grid-template-columns: 1fr; gap: 14px; }
}

.hl-testi-card {
  background: rgba(255,255,255,0.025);
  border: 1px solid rgba(233,194,125,0.12);
  border-radius: 16px;
  padding: 28px 22px 22px;
  position: relative;
  transition: transform 0.3s ease, border-color 0.3s ease;
  text-align: left;
}

.hl-testi-card:hover {
  transform: translateY(-4px);
  border-color: rgba(233,194,125,0.28);
}

.hl-testi-featured {
  border-color: rgba(233,194,125,0.28);
  background:
    radial-gradient(circle at top, rgba(233,194,125,0.07), transparent 60%),
    rgba(10,6,24,0.7);
  box-shadow: 0 12px 40px rgba(0,0,0,0.4), 0 0 1px rgba(233,194,125,0.3);
}

.hl-testi-quote {
  font-family: var(--font-serif);
  font-size: 3rem;
  color: var(--hl-gold);
  opacity: 0.35;
  line-height: 0.8;
  margin-bottom: 12px;
  font-weight: 300;
}

.hl-testi-text {
  font-size: 0.88rem;
  color: var(--hl-ink-soft);
  line-height: 2.0;
  font-weight: 300;
  margin-bottom: 16px;
  font-style: italic;
}

.hl-testi-author {
  display: flex;
  align-items: center;
  gap: 8px;
}

.hl-testi-name {
  font-size: 0.76rem;
  color: var(--hl-gold);
  letter-spacing: 1px;
  opacity: 0.7;
}

/* ── 3. 訂閱區 ── */
.hl-subscribe-card {
  background:
    radial-gradient(ellipse at center, rgba(233,194,125,0.07) 0%, transparent 65%),
    rgba(8,5,20,0.88) !important;
  border-color: rgba(233,194,125,0.22) !important;
}

.hl-subscribe-icon {
  font-size: 1.8rem;
  color: var(--hl-gold);
  margin-bottom: 16px;
  opacity: 0.6;
  letter-spacing: 8px;
}

.hl-subscribe-title {
  font-family: var(--font-serif);
  font-size: clamp(1.2rem, 3vw, 1.6rem);
  font-weight: 300;
  letter-spacing: 2px;
  background: linear-gradient(135deg, #fff9ea, #e9c27d 50%, #cda86e);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 16px;
  line-height: 1.5;
}

.hl-subscribe-desc {
  font-size: 0.88rem;
  color: var(--hl-ink-soft);
  line-height: 2.2;
  max-width: 520px;
  margin: 0 auto 28px;
  font-weight: 300;
}

.hl-ml-form {
  max-width: 480px;
  margin: 0 auto 16px;
}

/* 覆寫 MailerLite 表單樣式融入品牌 */
.hl-ml-form .ml-form-embedWrapper {
  background: transparent !important;
}

.hl-subscribe-note {
  font-size: 0.74rem;
  color: var(--hl-ink-muted);
  letter-spacing: 1px;
  opacity: 0.7;
}

/* ── 4. 手機底部固定 CTA ── */
.hl-mobile-sticky {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 8000;
  background: rgba(5,3,10,0.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1px solid rgba(233,194,125,0.2);
  padding: 12px 16px 16px;
  gap: 10px;
  align-items: center;
  justify-content: center;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
  box-shadow: 0 -8px 32px rgba(0,0,0,0.5);
}

.hl-mobile-sticky.is-visible {
  transform: translateY(0);
}

.hl-mobile-sticky.is-hidden {
  transform: translateY(100%);
}

.hl-mob-cta-draw {
  flex: 1;
  text-align: center;
  padding: 12px 16px;
  border-radius: 999px;
  background: linear-gradient(135deg, #e9c27d, #cda86e);
  color: #1a1008;
  font-size: 0.88rem;
  font-weight: 600;
  letter-spacing: 1px;
  text-decoration: none;
  transition: opacity 0.2s;
}

.hl-mob-cta-draw:active { opacity: 0.85; }

.hl-mob-cta-line {
  flex: 1;
  text-align: center;
  padding: 12px 16px;
  border-radius: 999px;
  background: rgba(233,194,125,0.08);
  border: 1px solid rgba(233,194,125,0.3);
  color: var(--hl-gold);
  font-size: 0.88rem;
  font-weight: 400;
  letter-spacing: 1px;
  text-decoration: none;
  transition: background 0.2s;
}

.hl-mob-cta-line:active { background: rgba(233,194,125,0.18); }

@media (max-width: 768px) {
  .hl-mobile-sticky { display: flex; }
  /* 避免底部按鈕被遮住，讓 footer 有底部間距 */
  .hl-footer { margin-bottom: 68px; }
}

@media (min-width: 769px) {
  .hl-mobile-sticky { display: none !important; }
}

/* ── 5. 首頁置頂 sticky mini nav ── */
.hl-home-nav {
  position: sticky;
  top: 0;
  z-index: 1000;
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  background: rgba(5,3,10,0.82);
  border-bottom: 1px solid rgba(233,194,125,0.12);
  padding: 0 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 52px;
  margin-bottom: 8px;
}

.hl-home-nav-brand {
  font-family: var(--font-serif);
  font-size: 0.88rem;
  letter-spacing: 2px;
  color: var(--hl-gold);
  font-weight: 300;
  opacity: 0.85;
  text-decoration: none;
}

.hl-home-nav-links {
  display: flex;
  align-items: center;
  gap: 6px;
}

.hl-home-nav-link {
  font-size: 0.8rem;
  color: var(--hl-ink-muted);
  text-decoration: none;
  padding: 6px 12px;
  border-radius: 999px;
  letter-spacing: 0.5px;
  transition: color 0.2s, background 0.2s;
  white-space: nowrap;
}

.hl-home-nav-link:hover {
  color: var(--hl-gold);
  background: rgba(233,194,125,0.08);
}

.hl-home-nav-cta {
  font-size: 0.78rem;
  color: #1a1008;
  background: linear-gradient(135deg, #e9c27d, #cda86e);
  border-radius: 999px;
  padding: 7px 18px;
  font-weight: 600;
  letter-spacing: 1px;
  text-decoration: none;
  transition: opacity 0.2s;
  white-space: nowrap;
}

.hl-home-nav-cta:hover { opacity: 0.88; color: #1a1008; }

@media (max-width: 600px) {
  .hl-home-nav-links { gap: 4px; }
  .hl-home-nav-link { display: none; }
  .hl-home-nav-cta { font-size: 0.76rem; padding: 6px 14px; }
  .hl-home-nav { padding: 0 12px; }
}

/* ── HOUR-LIGHT 城堡底圖層 ── */
.hl-bg-castle {
  position: fixed;
  inset: 0;
  z-index: -2;
  background: url('HOUR-LIGHT.png?v=20260308') center 30% / cover no-repeat;
  opacity: .20;
  filter: saturate(1.1) brightness(.72);
  pointer-events: none;
}
