<style>
/* =========================================
   今日幸運籤 Daily Oracle
   ========================================= */

/* 觸發浮鈕 */
.hl-lucky-fab {
  position: fixed;
  left: 20px;
  bottom: 24px;
  z-index: 8500;
  width: 52px;
  height: 52px;
  border-radius: 50%;
  border: 1px solid rgba(233,194,125,0.4);
  background: rgba(5,3,10,0.85);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 24px rgba(0,0,0,0.4), 0 0 16px rgba(233,194,125,0.12);
  transition: transform 0.3s ease, border-color 0.3s ease;
  overflow: visible;
}

.hl-lucky-fab:hover {
  transform: scale(1.08);
  border-color: var(--hl-gold, #e9c27d);
  box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 24px rgba(233,194,125,0.28);
}

