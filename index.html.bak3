<script>
/* =====================================================
   今日幸運籤 Daily Oracle Engine
   以當日日期為種子 → 全台灣今天同一張牌
   ===================================================== */
(function(){
  'use strict';

  // ── 130 張牌的代號清單（與 draw-hl.html 一致）──
  var ALL_CARDS = [
    'A00','A01','A02','A03','A04','A05','A06','A07','A08','A09','A10',
    'A11','A12','A13','A14','A15','A16','A17','A18','A19','A20','A21',
    '001','002','003','004','005','006','007','008','009','010',
    '011','012','013','014','015','016','017','018','019','020',
    '021','022','023','024','025','026','027','028','029','030',
    '031','032','033','034','035','036','037','038','039','040',
    '041','042','043','044','045','046','047','048','049','050',
    '051','052','053','054','055','056','057','058','059','060',
    '061','062','063','064','065','066','067','068','069','070',
    '071','072','073','074','075','076','077','078','079','080',
    '081','082','083','084','085','086','087','088','089','090',
    '091','092','093','094','095','096','097','098','099','100',
    '101','102','103','104','105','106','107','108'
  ];

  // ── 每日覺察問題庫（每天自動換一道）──
  var DAILY_QUESTIONS = [
    '今天，有什麼事讓你很難放下？那個放不下的，到底是在保護你還是在困住你？',
    '如果今天的你，可以對過去的自己說一句話，你會說什麼？',
    '你現在最需要被理解的一件事是什麼？',
    '最近哪個瞬間，你感覺到自己「活著」？',
    '今天有沒有什麼，是你明明知道但還是在逃避的？',
    '你上一次真正為自己做了一件事，是什麼時候？',
    '現在身體哪個地方，感覺最緊繃？那個緊繃在告訴你什麼？',
    '今天的你，如果是一個天氣，你是什麼天氣？',
    '有沒有一件事，你做了會後悔，但不做也會後悔？',
    '你最近在對誰太苛刻——對別人，還是對自己？',
    '如果你不怕失敗，你現在最想做的一件事是什麼？',
    '今天，你有沒有跟自己說過「謝謝你撐到今天」？',
    '你正在等待什麼？那個等待，是在等機會，還是在等許可？',
    '最近有沒有一個聲音，你一直壓著不讓它說話？',
    '如果把你現在的狀態比喻成一個房間，這個房間是什麼樣子？',
    '今天有什麼事讓你感到驕傲，即使沒有人知道？',
    '你現在最需要的：安靜，還是被看見？',
    '有沒有一個關係，你其實早就該說「我累了」？',
    '今天的你，是在往自己想去的方向走嗎？',
    '你最近的「夠好了嗎？」這個問題，有沒有稍微鬆動一點？',
    '如果今天的這張牌是你內心的一面鏡子，你看到了什麼？',
    '今天最讓你費心思的事，值得用這麼多能量嗎？',
    '你上一次讓自己「無聊」一下，是什麼時候？',
    '現在的你，需要的是前進，還是先停下來？',
    '今天有什麼事，讓你突然想起了某個人？'
  ];

  // ── 每日精簡訊息庫 ──
  var DAILY_MSGS = [
    '這張牌說的，也許剛好是你今天最不想承認、但最需要聽的那件事。',
    '今天的宇宙偷偷幫你抽了一張。不一定是答案，但絕對是一個問號。',
    '不是巧合。今天就是這張。你懂的。',
    '放下手機之前，先讓這張牌陪你坐一分鐘。',
    '有些話，只有牌卡才說得出口。今天，它替你說了。',
    '這張牌選擇了你今天。帶著它走一整天，看看會不會有什麼不一樣。',
    '你不是無緣無故打開這個頁面的。今天的牌，等你有一段時間了。',
    '今天的你，值得被這張牌好好看一眼。',
    '如果今天有點沉，這張牌想提醒你：你比你以為的更輕盈。',
    '今天的籤就是這張。玄不玄不重要，你感覺到什麼，才是重點。'
  ];

  // ── 日期種子函數（台灣時間，同一天全用同一張）──
  function getTodaySeed() {
    var now = new Date();
    // 轉台灣時間 UTC+8
    var twOffset = 8 * 60;
    var utcMs = now.getTime() + now.getTimezoneOffset() * 60000;
    var tw = new Date(utcMs + twOffset * 60000);
    return tw.getFullYear() * 10000 + (tw.getMonth() + 1) * 100 + tw.getDate();
  }

  function seededRandom(seed) {
    // 線性同餘生成器，夠用了
    var x = Math.sin(seed + 1) * 10000;
    return x - Math.floor(x);
  }

  function getTodayCardCode() {
    var seed = getTodaySeed();
    var idx = Math.floor(seededRandom(seed) * ALL_CARDS.length);
    return ALL_CARDS[idx];
  }

  function getTodayQuestion() {
    var seed = getTodaySeed() + 77;
    var idx = Math.floor(seededRandom(seed) * DAILY_QUESTIONS.length);
    return DAILY_QUESTIONS[idx];
  }

  function getTodayMsg() {
    var seed = getTodaySeed() + 333;
    var idx = Math.floor(seededRandom(seed) * DAILY_MSGS.length);
    return DAILY_MSGS[idx];
  }

  function formatTaiwanDate() {
    var now = new Date();
    var twOffset = 8 * 60;
    var utcMs = now.getTime() + now.getTimezoneOffset() * 60000;
    var tw = new Date(utcMs + twOffset * 60000);
    var wdays = ['日','一','二','三','四','五','六'];
    return tw.getFullYear() + ' 年 ' + (tw.getMonth()+1) + ' 月 ' + tw.getDate() + ' 日（週' + wdays[tw.getDay()] + '）';
  }

  // ── DOM 取得 ──
  var fab      = document.getElementById('luckyFab');
  var modal    = document.getElementById('luckyModal');
  var overlay  = document.getElementById('luckyOverlay');
  var closeBtn = document.getElementById('luckyClose');
  var frame    = document.getElementById('luckyCardFrame');
  var cardImg  = document.getElementById('luckyCardImg');
  var cardPlaceholder = document.getElementById('luckyCardPlaceholder');
  var cardCode = document.getElementById('luckyCardCode');
  var cardName = document.getElementById('luckyCardName');
  var msgEl    = document.getElementById('luckyMsgInner');
  var qEl      = document.getElementById('luckyQText');
  var dateEl   = document.getElementById('luckyDate');
  var shareBtn = document.getElementById('luckyShare');

  // ── 牌卡名稱（輕量備用，無需 cardData.js）──
  var CARD_NAMES_LITE = {
    'A00':'愚者之旅','A01':'魔法師','A02':'高女祭司','A03':'女皇',
    'A04':'皇帝','A05':'大祭司','A06':'戀人','A07':'戰車',
    'A08':'力量','A09':'隱士','A10':'命運之輪','A11':'正義',
    'A12':'倒吊人','A13':'死神','A14':'節制','A15':'惡魔',
    'A16':'高塔','A17':'星星','A18':'月亮','A19':'太陽',
    'A20':'審判','A21':'世界'
  };

  function getCardDisplayName(code) {
    // 優先從已載入的 cardData 取，否則用備用表
    if (window.cardData && window.cardData[code]) {
      return window.cardData[code].title || window.cardData[code].name || code;
    }
    if (CARD_NAMES_LITE[code]) return CARD_NAMES_LITE[code];
    // 精油牌只顯示編號
    return code;
  }

  // ── 載入牌卡圖片 ──
  function loadCard(code) {
    var imgSrc = code + '.png';
    var img = new Image();
    img.onload = function() {
      cardPlaceholder.style.display = 'none';
      cardImg.src = imgSrc;
      cardImg.alt = code;
      cardImg.style.display = 'block';
    };
    img.onerror = function() {
      // 圖片不存在時顯示美觀的佔位符
      cardPlaceholder.innerHTML = '<div style="text-align:center;color:#e9c27d;opacity:0.4;"><div style="font-size:2.5rem;margin-bottom:6px;">✦</div><div style="font-size:0.7rem;letter-spacing:2px;">' + code + '</div></div>';
    };
    img.src = imgSrc;
    cardCode.textContent = code;
    cardName.textContent = getCardDisplayName(code);
  }

  // ── 開啟 Modal ──
  function openLucky() {
    var code = getTodayCardCode();

    // 填入日期
    dateEl.textContent = formatTaiwanDate();

    // 填入訊息與問題
    msgEl.textContent = getTodayMsg();
    qEl.textContent = getTodayQuestion();

    // 重置牌卡翻轉狀態
    frame.classList.remove('is-flipped');
    cardPlaceholder.style.display = 'flex';
    cardImg.style.display = 'none';
    cardPlaceholder.innerHTML = '<div class="hl-lucky-spinner"></div>';

    // 開啟 modal
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';

    // 延遲翻牌 + 載入圖片
    setTimeout(function() {
      loadCard(code);
      setTimeout(function() {
        frame.classList.add('is-flipped');
      }, 400);
    }, 600);

    // 記錄今日已看（可選：記錄讓自動彈出不重複）
    try {
      var todayKey = 'hl-lucky-' + getTodaySeed();
      localStorage.setItem(todayKey, '1');
    } catch(e) {}
  }

  function closeLucky() {
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  // ── 事件綁定 ──
  fab.addEventListener('click', openLucky);
  closeBtn.addEventListener('click', closeLucky);
  overlay.addEventListener('click', closeLucky);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeLucky();
  });

  // ── 分享功能 ──
  shareBtn.addEventListener('click', function() {
    var code = getTodayCardCode();
    var name = getCardDisplayName(code);
    var txt = '今天的馥靈幸運籤是「' + name + '」✨\n' + getTodayMsg() + '\n\n今日覺察：' + getTodayQuestion() + '\n\n👉 hourlightkey.com';
    if (navigator.share) {
      navigator.share({ title: '今日幸運籤｜馥靈之鑰', text: txt, url: 'https://hourlightkey.com' }).catch(function(){});
    } else if (navigator.clipboard) {
      navigator.clipboard.writeText(txt).then(function() {
        shareBtn.textContent = '✅ 已複製！';
        setTimeout(function() {
          shareBtn.innerHTML = '<span class="zh">📤 分享今日籤</span><span class="en">📤 Share</span>';
        }, 2000);
      }).catch(function(){});
    } else {
      alert(txt);
    }
  });

  // ── 每日首次自動彈出（進站 2 秒後，今天第一次才彈）──
  try {
    var todayKey = 'hl-lucky-' + getTodaySeed();
    var alreadySeen = localStorage.getItem(todayKey);
    if (!alreadySeen) {
      setTimeout(openLucky, 2200);
    }
  } catch(e) {
    // localStorage 不可用時不自動彈，依靠浮鈕
  }

})();
</script>


<!-- HL 轉化 CTA（展示頁用） -->
<script src="assets/js/firebase-config.js"></script>
<script src="assets/js/hl-convert-cta.js" data-page-type="home"></script>
<script>
/* ── CTA bar 與 mobile sticky bar 共存修正 ── */
(function(){
  function adjustForCTA(bar){
    if(!bar) return;
    var h = bar.offsetHeight || 72;
    var sticky = document.getElementById('mobileStickyBar');
    if(sticky && window.innerWidth <= 768){
      sticky.style.bottom = h + 'px';
      // 同步 footer margin
      var footer = document.querySelector('.hl-footer');
      if(footer) footer.style.marginBottom = (h + 68) + 'px';
    }
    bar.addEventListener('transitionend', function onHide(){
      if(bar.style.transform === 'translateY(100%)'){
        if(sticky) sticky.style.bottom = '';
        var footer = document.querySelector('.hl-footer');
        if(footer) footer.style.marginBottom = '';
        bar.removeEventListener('transitionend', onHide);
      }
    });
  }
  // 監聽 CTA bar 被注入
  new MutationObserver(function(mutations){
    mutations.forEach(function(m){
      m.addedNodes.forEach(function(n){
        if(n.id === 'hl-convert-cta') adjustForCTA(n);
      });
    });
  }).observe(document.body, {childList: true});
})();
</script>
</body>
</html>
