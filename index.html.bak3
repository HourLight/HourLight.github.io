<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet">
<style>
/* ── GRAVITAS OVERRIDE ── */
:root {
  --g-gold:    #d4a853;
  --g-gold-lt: #e8c87a;
  --g-gold-dk: #a07830;
  --g-ink:     #0a0814;
  --g-cream:   #faf6ee;
  --g-white:   #ffffff;
  --g-warm:    rgba(255,255,255,.55);
  --g-serif:   'LXGW WenKai TC','Noto Serif TC',serif;
  --g-italic:  'Cormorant Garamond',Georgia,serif;
  --g-ease:    cubic-bezier(.4,0,.2,1);
}

/* ─── NAV 重設計 ─── */
.hl-home-nav {
  background: rgba(10,8,20,.96) !important;
  backdrop-filter: blur(20px) !important;
  -webkit-backdrop-filter: blur(20px) !important;
  border-bottom: 1px solid rgba(212,168,83,.15) !important;
  height: 56px !important;
  padding: 0 40px !important;
}
.hl-home-nav-brand {
  font-family: var(--g-serif) !important;
  font-size: .92rem !important;
  letter-spacing: 3px !important;
  font-weight: 400 !important;
}
.hl-home-nav-link {
  font-size: .76rem !important;
  letter-spacing: 1.5px !important;
  opacity: .65 !important;
  transition: opacity .25s !important;
}
.hl-home-nav-link:hover { opacity: 1 !important; }
.hl-home-nav-cta {
  padding: 7px 20px !important;
  border-radius: 999px !important;
  font-size: .76rem !important;
  letter-spacing: 1.5px !important;
  background: linear-gradient(135deg, var(--g-gold-lt), var(--g-gold)) !important;
  color: #1a0e00 !important;
  font-weight: 500 !important;
  border: none !important;
  box-shadow: 0 4px 14px rgba(212,168,83,.3) !important;
  transition: all .25s var(--g-ease) !important;
}
.hl-home-nav-cta:hover {
  transform: translateY(-1px) !important;
  box-shadow: 0 6px 20px rgba(212,168,83,.45) !important;
}
@media(max-width:680px){.hl-home-nav{padding:0 18px!important;}}

/* ─── HERO 重設計 ─── */
.hero-card {
  border-radius: 0 !important;
  margin-bottom: 0 !important;
  border-left: none !important;
  border-right: none !important;
  border-top: none !important;
  background:
    radial-gradient(ellipse 70% 60% at 50% 20%, rgba(212,168,83,.10), transparent),
    radial-gradient(ellipse 40% 50% at 20% 80%, rgba(80,40,120,.07), transparent),
    rgba(8,5,18,.97) !important;
}
.hero {
  padding: 110px 40px 80px !important;
  max-width: 720px !important;
  margin: 0 auto !important;
  text-align: center !important;
}
.hero-label {
  font-family: var(--g-italic) !important;
  font-style: italic !important;
  font-size: .72rem !important;
  letter-spacing: 5px !important;
  color: var(--g-gold) !important;
  opacity: .7 !important;
  margin-bottom: 32px !important;
}
.hero-brand-name {
  font-family: var(--g-serif) !important;
  font-size: clamp(1rem,2.5vw,1.2rem) !important;
  letter-spacing: 5px !important;
  color: rgba(255,255,255,.5) !important;
  margin-bottom: 20px !important;
  -webkit-background-clip: unset !important;
  -webkit-text-fill-color: unset !important;
}
.hero-title {
  font-family: var(--g-serif) !important;
  font-size: clamp(2rem,5vw,3rem) !important;
  font-weight: 300 !important;
  letter-spacing: 4px !important;
  line-height: 1.5 !important;
  background: linear-gradient(135deg, #fff9ea 0%, #fbe6c2 20%, #e8c87a 50%, #d4a853 80%, #fff9ea 100%) !important;
  background-size: 200% 200% !important;
  -webkit-background-clip: text !important;
  -webkit-text-fill-color: transparent !important;
  margin-bottom: 36px !important;
}
.hero-philosophy {
  font-family: var(--g-serif) !important;
  font-size: clamp(1rem,2vw,1.15rem) !important;
  color: rgba(255,255,255,.6) !important;
  max-width: 500px !important;
  margin: 0 auto 20px !important;
  line-height: 2.4 !important;
  letter-spacing: 1px !important;
  opacity: 1 !important;
}
.hero-divider {
  width: 48px !important;
  height: 1px !important;
  background: linear-gradient(90deg, transparent, var(--g-gold), transparent) !important;
  margin: 28px auto !important;
}
.hero-desc {
  font-size: clamp(.88rem,1.6vw,.97rem) !important;
  color: rgba(255,255,255,.5) !important;
  line-height: 2.3 !important;
  max-width: 520px !important;
  margin: 0 auto 40px !important;
}
.hero-cta-row { gap: 16px !important; }
.hero-cta-main {
  display: inline-block !important;
  padding: 16px 40px !important;
  border-radius: 999px !important;
  font-size: .92rem !important;
  letter-spacing: 2px !important;
  font-weight: 500 !important;
  background: linear-gradient(135deg, var(--g-gold-lt), var(--g-gold)) !important;
  color: #1a0e00 !important;
  box-shadow: 0 10px 32px rgba(212,168,83,.4) !important;
  transition: all .25s var(--g-ease) !important;
  text-decoration: none !important;
  -webkit-text-fill-color: #1a0e00 !important;
}
.hero-cta-main:hover {
  transform: translateY(-2px) !important;
  box-shadow: 0 14px 40px rgba(212,168,83,.55) !important;
}
.hero-cta-secondary {
  color: rgba(255,255,255,.55) !important;
  font-size: .85rem !important;
  letter-spacing: 1px !important;
  text-decoration: none !important;
  border-bottom: 1px solid rgba(212,168,83,.25) !important;
  padding-bottom: 3px !important;
  transition: all .25s !important;
}
.hero-cta-secondary:hover {
  color: var(--g-gold-lt) !important;
  border-color: var(--g-gold) !important;
}
.hero-secondary-links a {
  color: rgba(255,255,255,.3) !important;
  font-size: .78rem !important;
  letter-spacing: 2px !important;
  text-decoration: none !important;
  transition: color .25s !important;
}
.hero-secondary-links a:hover { color: rgba(255,255,255,.6) !important; }

/* ─── 社會證明欄 ─── */
.hl-proof-bar {
  background: linear-gradient(135deg, var(--g-gold-lt), var(--g-gold)) !important;
  border-radius: 0 !important;
  margin-bottom: 0 !important;
  display: grid !important;
  grid-template-columns: repeat(4,1fr) !important;
  border: none !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
}
.hl-proof-item {
  padding: 24px 20px !important;
  border-right: 1px solid rgba(26,14,0,.12) !important;
  text-align: center !important;
}
.hl-proof-item:last-child { border-right: none !important; }
.hl-proof-num {
  font-family: var(--g-serif) !important;
  font-size: clamp(1.3rem,3vw,1.8rem) !important;
  font-weight: 300 !important;
  color: #1a0e00 !important;
  display: block !important;
  line-height: 1 !important;
  letter-spacing: 1px !important;
}
.hl-proof-label {
  font-size: .7rem !important;
  color: rgba(26,14,0,.65) !important;
  letter-spacing: 1.5px !important;
  margin-top: 4px !important;
  line-height: 1.5 !important;
}
.hl-proof-divider { display: none !important; }
@media(max-width:680px){
  .hl-proof-bar{grid-template-columns:repeat(2,1fr)!important;}
  .hl-proof-item{padding:18px 14px!important;border-bottom:1px solid rgba(26,14,0,.1)!important;}
  .hl-proof-item:nth-child(even){border-right:none!important;}
}

/* ─── 卡片通用 ─── */
.card {
  border-radius: 0 !important;
  margin-bottom: 0 !important;
  background: rgba(14,12,20,.97) !important;
  border: none !important;
  border-top: 1px solid rgba(212,168,83,.1) !important;
  box-shadow: none !important;
  backdrop-filter: none !important;
}

/* ─── 章節通用 ─── */
.section { padding: 80px 40px !important; max-width: 900px; margin: 0 auto; }
.section-label {
  font-family: var(--g-italic) !important;
  font-style: italic !important;
  font-size: .68rem !important;
  letter-spacing: 5px !important;
  color: var(--g-gold) !important;
  opacity: .6 !important;
  margin-bottom: 14px !important;
}
.section-title {
  font-family: var(--g-serif) !important;
  font-size: clamp(1.3rem,3vw,1.9rem) !important;
  font-weight: 300 !important;
  letter-spacing: 2px !important;
  line-height: 1.5 !important;
  background: linear-gradient(135deg, #fff9ea, #e8c87a, #d4a853) !important;
  -webkit-background-clip: text !important;
  -webkit-text-fill-color: transparent !important;
  margin-bottom: 36px !important;
}
.section-divider {
  width: 40px !important;
  height: 1px !important;
  background: var(--g-gold) !important;
  margin: 20px auto 36px !important;
  display: block !important;
  border: none !important;
}

/* ─── 三大入口卡片 ─── */
.grid-3 {
  display: grid !important;
  grid-template-columns: repeat(3,1fr) !important;
  gap: 2px !important;
  background: rgba(212,168,83,.12) !important;
  border-radius: 4px !important;
  overflow: hidden !important;
  margin-top: 36px !important;
}
.item-card {
  padding: 36px 28px !important;
  border-radius: 0 !important;
  background: rgba(14,12,20,.98) !important;
  border: none !important;
  box-shadow: none !important;
  transition: background .3s var(--g-ease) !important;
  text-decoration: none !important;
  display: block !important;
}
.item-card:hover {
  background: rgba(212,168,83,.07) !important;
  transform: none !important;
}
.item-card .title {
  font-family: var(--g-serif) !important;
  font-size: .97rem !important;
  font-weight: 400 !important;
  color: rgba(255,255,255,.85) !important;
  letter-spacing: 1.5px !important;
  margin-bottom: 12px !important;
}
.item-card .text {
  font-size: .84rem !important;
  color: rgba(255,255,255,.45) !important;
  line-height: 2 !important;
}
@media(max-width:680px){.grid-3{grid-template-columns:1fr!important;}.item-card{padding:28px 20px!important;}}

/* ─── 工具標籤 ─── */
.tools-row { display: flex !important; flex-wrap: wrap !important; justify-content: center !important; gap: 10px !important; }
.tool-chip {
  padding: 7px 18px !important;
  border: 1px solid rgba(212,168,83,.25) !important;
  border-radius: 999px !important;
  font-size: .78rem !important;
  color: rgba(255,255,255,.5) !important;
  text-decoration: none !important;
  letter-spacing: 1px !important;
  transition: all .25s !important;
  background: transparent !important;
}
.tool-chip:hover {
  border-color: var(--g-gold) !important;
  color: var(--g-gold-lt) !important;
  background: rgba(212,168,83,.06) !important;
}

/* ─── 見證橫幅 ─── */
.hl-testimonial-bar {
  background: transparent !important;
  border: 1px solid rgba(212,168,83,.15) !important;
  border-left: none !important;
  border-right: none !important;
  padding: 32px 40px !important;
}
.hl-testimonial-text {
  font-family: var(--g-serif) !important;
  font-size: clamp(.9rem,2vw,1.05rem) !important;
  color: rgba(255,255,255,.55) !important;
  letter-spacing: 1px !important;
  line-height: 2 !important;
  font-weight: 300 !important;
  font-style: italic !important;
}
.hl-testimonial-text strong {
  color: var(--g-gold-lt) !important;
  font-style: normal !important;
}

/* ─── 創辦人 ─── */
.founder-mini {
  display: grid !important;
  grid-template-columns: 200px 1fr !important;
  gap: 48px !important;
  align-items: center !important;
}
.founder-avatar {
  width: 180px !important;
  height: 240px !important;
  border-radius: 4px !important;
  object-fit: cover !important;
  object-position: center top !important;
  filter: grayscale(15%) !important;
  border: 1px solid rgba(212,168,83,.3) !important;
}
.founder-name {
  font-family: var(--g-serif) !important;
  font-size: clamp(1.4rem,3vw,1.8rem) !important;
  font-weight: 300 !important;
  letter-spacing: 4px !important;
  background: linear-gradient(135deg, #fff9ea, #e8c87a, #d4a853) !important;
  -webkit-background-clip: text !important;
  -webkit-text-fill-color: transparent !important;
  margin-bottom: 4px !important;
  animation: none !important;
}
.founder-role {
  font-size: .78rem !important;
  color: var(--g-gold) !important;
  letter-spacing: 2px !important;
  opacity: .7 !important;
  margin-bottom: 20px !important;
}
.founder-quote {
  font-family: var(--g-serif) !important;
  font-size: clamp(.92rem,1.8vw,1.05rem) !important;
  color: rgba(255,255,255,.65) !important;
  line-height: 2.3 !important;
  letter-spacing: .5px !important;
  border-left: 2px solid rgba(212,168,83,.4) !important;
  padding-left: 20px !important;
  margin-bottom: 24px !important;
  font-weight: 300 !important;
}
@media(max-width:680px){
  .founder-mini{grid-template-columns:1fr!important;gap:28px!important;text-align:center!important;}
  .founder-avatar{width:140px!important;height:180px!important;margin:0 auto!important;display:block!important;}
  .founder-quote{text-align:left!important;}
}

/* ─── 著作 ─── */
.book-grid {
  display: grid !important;
  grid-template-columns: repeat(3,1fr) !important;
  gap: 2px !important;
  margin-top: 36px !important;
  background: rgba(212,168,83,.1) !important;
  border-radius: 4px !important;
  overflow: hidden !important;
}
.book-item {
  background: rgba(14,12,20,.98) !important;
  padding: 32px 24px !important;
  text-decoration: none !important;
  display: block !important;
  transition: background .3s !important;
}
.book-item:hover { background: rgba(212,168,83,.06) !important; }
.book-cover {
  aspect-ratio: 3/4 !important;
  background: linear-gradient(160deg, rgba(42,36,53,.95), rgba(14,12,20,1)) !important;
  border-radius: 2px !important;
  display: flex !important;
  flex-direction: column !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 20px !important;
  text-align: center !important;
  margin-bottom: 16px !important;
  border: 1px solid rgba(212,168,83,.15) !important;
  box-shadow: none !important;
}
.book-num {
  font-family: var(--g-italic) !important;
  font-style: italic !important;
  font-size: 3rem !important;
  color: rgba(212,168,83,.2) !important;
  line-height: 1 !important;
  margin-bottom: 10px !important;
}
.book-title-inner {
  font-family: var(--g-serif) !important;
  font-size: .85rem !important;
  color: var(--g-gold-lt) !important;
  line-height: 1.8 !important;
  letter-spacing: 1px !important;
}
.book-desc-text {
  font-size: .82rem !important;
  color: rgba(255,255,255,.4) !important;
  line-height: 1.8 !important;
}
@media(max-width:600px){.book-grid{grid-template-columns:1fr!important;}}

/* ─── 美業夥伴 ─── */
.partner-grid {
  display: grid !important;
  grid-template-columns: 1fr 1fr !important;
  gap: 2px !important;
  margin-top: 36px !important;
  background: rgba(212,168,83,.1) !important;
  border-radius: 4px !important;
  overflow: hidden !important;
}
.partner-card {
  background: rgba(14,12,20,.98) !important;
  padding: 36px 32px !important;
  text-decoration: none !important;
  display: block !important;
  transition: background .3s !important;
}
.partner-card:hover { background: rgba(212,168,83,.06) !important; }
.partner-icon { font-size: 2rem !important; margin-bottom: 12px !important; display: block !important; }
.partner-title {
  font-family: var(--g-serif) !important;
  font-size: .97rem !important;
  color: rgba(255,255,255,.85) !important;
  letter-spacing: 1.5px !important;
  margin-bottom: 8px !important;
  font-weight: 400 !important;
}
.partner-desc { font-size: .83rem !important; color: rgba(255,255,255,.4) !important; line-height: 2 !important; }
@media(max-width:580px){.partner-grid{grid-template-columns:1fr!important;}}

/* ─── 訂閱 ─── */
.subscribe-card {
  text-align: center !important;
  padding: 60px 40px !important;
  background: rgba(212,168,83,.04) !important;
  border-top: 1px solid rgba(212,168,83,.12) !important;
}

/* ─── 結尾 ─── */
.ending-card {
  text-align: center !important;
  padding: 80px 40px !important;
}
.ending-title {
  font-family: var(--g-serif) !important;
  font-size: clamp(1.5rem,4vw,2.2rem) !important;
  font-weight: 300 !important;
  letter-spacing: 3px !important;
  line-height: 1.7 !important;
  background: linear-gradient(135deg, #fff9ea, #e8c87a, #d4a853) !important;
  -webkit-background-clip: text !important;
  -webkit-text-fill-color: transparent !important;
  margin-bottom: 20px !important;
}
.ending-sub {
  color: rgba(255,255,255,.45) !important;
  font-size: .9rem !important;
  line-height: 2.2 !important;
  max-width: 480px !important;
  margin: 0 auto 40px !important;
}
.btn-ending-primary {
  display: inline-block !important;
  padding: 16px 44px !important;
  border-radius: 999px !important;
  background: linear-gradient(135deg, var(--g-gold-lt), var(--g-gold)) !important;
  color: #1a0e00 !important;
  font-size: .92rem !important;
  font-weight: 500 !important;
  letter-spacing: 2px !important;
  text-decoration: none !important;
  transition: all .25s var(--g-ease) !important;
  box-shadow: 0 10px 32px rgba(212,168,83,.35) !important;
  -webkit-text-fill-color: #1a0e00 !important;
}
.btn-ending-primary:hover { transform: translateY(-2px) !important; box-shadow: 0 14px 40px rgba(212,168,83,.55) !important; }

/* container */
.container { max-width: 100% !important; padding: 0 !important; }

/* fade-in-up 保留 */
.fade-in-up { animation: gravitas-fade-in .8s var(--g-ease) forwards; opacity: 0; }
@keyframes gravitas-fade-in { from { opacity:0; transform:translateY(24px); } to { opacity:1; transform:none; } }
</style>
</head>

