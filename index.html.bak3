<!-- ========== 浮動 LINE 按鈕（玻璃擬態）========== -->
<a href="https://lin.ee/OQDB5t6" target="_blank" rel="noopener" class="hl-float-line" id="floatLine">
  <span class="hl-float-line-icon">💬</span>
  <span class="hl-float-line-text">LINE 諮詢</span>
</a>
<script>
(function(){
  var btn=document.getElementById('floatLine');
  var footer=document.querySelector('.hl-footer');
  if(!btn||!footer)return;
  window.addEventListener('scroll',function(){
    var ft=footer.getBoundingClientRect().top;
    var wh=window.innerHeight;
    if(ft<wh+20){btn.style.opacity='0';btn.style.pointerEvents='none';}
    else{btn.style.opacity='1';btn.style.pointerEvents='auto';}
  },{passive:true});
})();
</script>
<!-- ========== End 浮動 LINE 按鈕 ========== -->

<script>
// ===== 手機底部 Sticky CTA 控制 =====
(function(){
  var bar = document.getElementById('mobileStickyBar');
  var hero = document.querySelector('.hero-card');
  var footer = document.querySelector('.hl-footer');
  if (!bar) return;
  var lastScroll = 0;
  function updateBar() {
    var scrollY = window.scrollY || window.pageYOffset;
    var heroBottom = hero ? hero.getBoundingClientRect().bottom + scrollY : 300;
    var footerTop = footer ? footer.getBoundingClientRect().top + scrollY : 99999;
    var wh = window.innerHeight;
    // 顯示條件：捲過 hero && 還沒接近 footer
    if (scrollY > heroBottom - 100 && (scrollY + wh) < footerTop + 80) {
      bar.classList.add('is-visible');
      bar.classList.remove('is-hidden');
    } else {
      bar.classList.remove('is-visible');
      bar.classList.add('is-hidden');
    }
    lastScroll = scrollY;
  }
  window.addEventListener('scroll', updateBar, { passive: true });
  setTimeout(updateBar, 800);
})();
</script>

<script>
// ===== 語言切換系統 =====
function setLang(lang) {
  document.body.classList.toggle('lang-en', lang === 'en');
  document.getElementById('btnZh').classList.toggle('active', lang === 'zh');
  document.getElementById('btnEn').classList.toggle('active', lang === 'en');
  try { localStorage.setItem('hl-lang', lang); } catch(e) {}
}
// 初始化：讀取記憶
(function() {
  try {
    var saved = localStorage.getItem('hl-lang');
    if (saved === 'en') setLang('en');
  } catch(e) {}
})();
</script>
