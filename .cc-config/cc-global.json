{
  "version": "1.0.0",
  "name": "Claude Code 馥靈之鑰系統",
  "description": "跨裝置 Claude Code 啟動器與智能指令系統",
  "projectRoot": "D:\\OneDrive\\桌面\\HourLight.github.io",

  "system": {
    "autoSync": true,
    "syncInterval": "15min",
    "maxLogFiles": 10,
    "debugMode": false,
    "language": "zh-TW"
  },

  "devices": {
    "registered": [],
    "maxDevices": 10,
    "autoDetect": true,
    "syncConflictResolution": "timestamp"
  },

  "commands": {
    "enableAliases": true,
    "enableUsageStats": true,
    "enableAutoComplete": true,
    "commandTimeout": 30000,
    "maxHistorySize": 100
  },

  "security": {
    "enablePermissions": true,
    "requireConfirmation": [
      "admin",
      "sync",
      "delete"
    ],
    "encryptSensitiveData": true
  },

  "sync": {
    "onedrive": {
      "enabled": true,
      "watchMode": true,
      "conflictResolution": "prompt"
    },
    "git": {
      "enabled": true,
      "autoCommit": true,
      "commitMessage": "CC自動同步: {timestamp}",
      "autoPush": false
    }
  },

  "ui": {
    "theme": "dark",
    "showProgress": true,
    "showTimestamps": true,
    "enableNotifications": true,
    "defaultBrowser": "default"
  },

  "integrations": {
    "socialEngine": {
      "enabled": true,
      "path": "tools/social-engine"
    },
    "adminDashboard": {
      "enabled": true,
      "path": "admin-dashboard.html"
    },
    "contentTools": {
      "enabled": true,
      "path": "tools/content"
    }
  },

  "profiles": {
    "default": "work-profile",
    "available": [
      "work-profile",
      "content-creation",
      "admin-tasks",
      "development"
    ]
  },

  "shortcuts": {
    "global": {
      "cc": "help",
      "cc h": "help",
      "cc ?": "help",
      "cc s": "social",
      "cc c": "content",
      "cc a": "admin",
      "cc sync": "sync all",
      "cc st": "status",
      "cc q": "quit"
    }
  },

  "notifications": {
    "syncSuccess": true,
    "commandComplete": false,
    "errors": true,
    "warnings": true
  },

  "performance": {
    "enableCaching": true,
    "cacheTimeout": "1h",
    "enableLazyLoading": true,
    "maxConcurrentTasks": 3
  },

  "logging": {
    "level": "info",
    "enableFile": true,
    "enableConsole": true,
    "logDirectory": ".cc-config/logs",
    "rotateDaily": true
  },

  "features": {
    "voiceCommands": false,
    "webInterface": true,
    "mobileApp": true,
    "automation": true,
    "aiAssistance": false
  },

  "branding": {
    "name": "馥靈之鑰 Claude Code",
    "version": "1.0.0",
    "description": "讀懂自己，活對人生 - 跨裝置智能指令系統",
    "website": "https://hourlightkey.com",
    "support": "https://github.com/anthropics/claude-code/issues"
  },

  "metadata": {
    "createdAt": "2026-04-13T17:45:00Z",
    "lastUpdated": "2026-04-13T17:45:00Z",
    "createdBy": "Claude Code Launcher v1.0",
    "configVersion": "1.0"
  }
}