{
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "app.hourlightkey.com" }],
      "destination": "/app.html",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/cron-post",
      "schedule": "30 23 * * *"
    },
    {
      "path": "/api/cron-post",
      "schedule": "15 4 * * *"
    },
    {
      "path": "/api/cron-post",
      "schedule": "0 12 * * *"
    }
  ]
}
