rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in ['judyanee@gmail.com', 'info@hourlightkey.com', 'judyanee@hotmail.com'];
    }

    match /users/{userId} {
      allow read: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      // 2026/04/15 修正：admin 需要能寫別人的 users doc（快速開通會員 + 客服補償）
      // 原本只有 request.auth.uid == userId，admin 寫其他用戶會 Missing or insufficient permissions
      allow write: if (request.auth != null && request.auth.uid == userId) || isAdmin();

      match /ai_weekly/{weekKey} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId
          && request.resource.data.keys().hasOnly(['count', 'lastUsed'])
          && request.resource.data.count is int
          && request.resource.data.count >= 0
          && request.resource.data.count <= 100;
      }

      match /courses/{courseId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      match /draw_history/{drawId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
        allow delete: if false;
      }

      match /quiz_results/{quizId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && request.auth.uid == userId;
        allow delete: if false;
      }

      match /ai_daily/{dayKey} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /analyses/{analysisId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /vouchers/{voucherId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /history/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
      }

      match /pending_rewards/{rewardId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /points/{pointId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /tarot_daily/{dayKey} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      match /{toolDaily}/{dayKey} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /public/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /admin/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /unlock_codes/{codeId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    match /reading_codes/{codeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    match /promo_redemptions/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /commissions/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin();
    }

    match /april_gifts/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /april_gifts_r2/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /april_gifts_r3/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /referral_rewards/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /pet_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /family_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /spa_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /nail_sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /feedback/{docId} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    match /events/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /pendingOrders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    match /biz_partners/{partnerId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['usedThisMonth', 'quotaResetDate']);

      match /biz_codes/{codeId} {
        allow read: if true;
        allow write: if isAdmin();
        allow update: if request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['used', 'usedAt']);
      }
    }

    match /{path=**}/biz_codes/{codeId} {
      allow read: if true;
    }

    match /wallpaper_feedback/{feedbackId} {
      allow read: if true;
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.text is string
        && request.resource.data.text.size() >= 5
        && request.resource.data.text.size() <= 500;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /announcements/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /chat_logs/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /courseProgress/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /partner_payouts/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /partner_referrals/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /readings/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
      allow delete: if false;
    }

    match /referral_events/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /referrals/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ruby_brain/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /trial_codes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /voucher_log/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    match /wallpaper_generations/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if false;
    }

    match /wallpaper_quota/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /yijing_diary/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    match /businesses/{bizId} {
      allow read: if true;
      allow write: if isAdmin();

      match /services/{serviceId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /staff/{staffId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /slots/{slotId} {
        allow read: if true;
        allow create: if isAdmin();
        allow delete: if isAdmin();
        allow update: if isAdmin()
          || (request.auth != null
              && resource.data.status == 'open'
              && request.resource.data.status == 'booked'
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'bookedBy', 'bookedAt']));
      }

      match /bookings/{bookingId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if isAdmin()
          || (request.auth != null
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'paidAt']));
        allow delete: if isAdmin();
      }

      match /shifts/{shiftId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /schedule/{scheduleId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /addons/{addonId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }
  }
}
